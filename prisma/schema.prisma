generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Sender {
  id                String              @id @default(cuid())
  name              String
  gstNumber         String              @default("")
  nextInvoiceNum    Int                 @default(1)
  signature         String              @default("")
  isActive          Boolean             @default(true)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  invoices          Invoice[]
  electricityBills  ElectricityBill[]
}

model Building {
  id                String              @id @default(cuid())
  name              String
  address           String              @default("")
  isActive          Boolean             @default(true)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  tenants           Tenant[]
  invoices          Invoice[]
  electricityBills  ElectricityBill[]
}

model Tenant {
  id                  String              @id @default(cuid())
  name                String
  email               String              @default("")
  ccEmails            String              @default("")
  phone               String              @default("")
  propertyAddress     String
  gstNumber           String              @default("")
  buildingId          String?
  building            Building?           @relation(fields: [buildingId], references: [id])
  defaultRent         Float               @default(0)
  defaultDescription  String              @default("Amount Charged towards rental of the premises")
  elecMultiplier      Int                 @default(15)
  elecMinChargeUnits  Int                 @default(0)
  elecKVA             Int                 @default(375)
  elecBWSSB           Float               @default(0)
  elecMaintenance     Float               @default(0)
  elecDgMaintenance   Float               @default(0)
  elecWaterCharges    Float               @default(0)
  isActive            Boolean             @default(true)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  invoices            Invoice[]
  electricityBills    ElectricityBill[]
}

model Invoice {
  id              String    @id @default(cuid())
  invoiceNumber   String
  senderId        String
  sender          Sender    @relation(fields: [senderId], references: [id])
  buildingId      String    @default("")
  building        Building? @relation(fields: [buildingId], references: [id])
  tenantId        String
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoiceDate     DateTime  @default(now())
  month           String
  year            Int
  description     String    @default("Amount Charged towards rental of the premises")
  baseRent        Float
  cgstRate        Float     @default(9.0)
  sgstRate        Float     @default(9.0)
  cgstAmount      Float
  sgstAmount      Float
  totalAmount     Float
  status          String    @default("DRAFT")
  sentAt          DateTime?
  pdfPath         String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Settings {
  id              String   @id @default("default")
  senderPhone     String   @default("")
  senderEmail     String   @default("")
  smtpHost        String   @default("smtp.gmail.com")
  smtpPort        Int      @default(587)
  smtpUser        String   @default("")
  smtpPass        String   @default("")
  paymentTerms    String   @default("Payment due within 15 days of invoice date.")
  bankDetails     String   @default("")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model ElectricityBill {
  id                  String    @id @default(cuid())
  senderId            String
  sender              Sender    @relation(fields: [senderId], references: [id])
  buildingId          String    @default("")
  building            Building? @relation(fields: [buildingId], references: [id])
  tenantId            String
  tenant              Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  month               String
  year                Int
  billDate            DateTime  @default(now())
  openingReading      Float
  closingReading      Float
  unitsConsumed       Float
  totalUnitsConsumed  Float
  miscUnits           Float     @default(0)
  totalUnitsCharged   Float
  ratePerUnit         Float
  totalAmount         Float
  minChargeUnits      Int
  kva                 Int
  minimumCharge       Float
  bwssbCharges        Float     @default(0)
  maintenance         Float     @default(0)
  dgMaintenance       Float     @default(0)
  waterCharges        Float     @default(0)
  netPayable          Float
  invoiceNo           String    @default("")
  status              String    @default("DRAFT")
  sentAt              DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}
